{
    "name": "samuel-lar-enr/proyecto-trasteros-backend",
    "description": "Backend for projecto-trasteros in PHP",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require": {
        "firebase/php-jwt": "^6.11",
        "google/apiclient": "^2.14",
        "phpmailer/phpmailer": "^7.0",
        "slim/psr7": "^1.8",
        "slim/slim": "^4.15",
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
