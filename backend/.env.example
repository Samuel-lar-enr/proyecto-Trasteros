# ========================================
# DATABASE CONFIGURATION
# ========================================
MYSQL_ROOT_PASSWORD=admin123
MYSQL_DATABASE=auth_db
MYSQL_USER=admin
MYSQL_PASSWORD=admin123

# URL de conexión a MySQL
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://admin:admin123@mysql:3306/auth_db

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=3000
NODE_ENV=development

# ========================================
# AUTHENTICATION CONFIGURATION
# ========================================

# AUTH_REQUIRED: Controla si los endpoints CRUD requieren autenticación
# - false: Los endpoints funcionan SIN token (ideal para desarrollo/alumnos principiantes)
# - true: Los endpoints REQUIEREN token JWT (modo producción/alumnos avanzados)
AUTH_REQUIRED=false

# JWT Secret: Clave secreta para firmar tokens (cambiar en producción)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-please

# JWT Expiration: Tiempo de validez del token (ejemplos: 1h, 24h, 7d, 30d)
JWT_EXPIRES_IN=24h

# Google Auth: ID de cliente de Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# ========================================
# EMAIL CONFIGURATION (SMTP)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Trasteros App"
FROM_EMAIL=your-email@gmail.com

# Frontend URL for activation links
FRONTEND_URL=http://localhost:5173
# Para hacer la activacion de cuentas directamente desde el backend
# FRONTEND_URL=http://localhost:3000/api/auth/activate/