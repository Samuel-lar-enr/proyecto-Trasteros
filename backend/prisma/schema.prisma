generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = "mysql://boxen:Granada2026%21@23.229.232.2:3306/boxen"
}

model User {
  id                   Int        @id @default(autoincrement())
  userType             UserType   @default(PARTICULAR) @map("user_type")
  role                 Role       @default(USER) @map("role")
  email                String     @unique
  passwordHash         String?    @map("password_hash")
  googleId             String?    @unique @map("google_id")
  passwordReminder     String?    @map("password_reminder")
  name                 String
  surname              String?    @map("surname")
  dniNif               String?    @unique @map("dni_nif")
  commercialName       String?    @map("commercial_name")
  nifCif               String?    @map("nif_cif")
  address              String?    @map("address")
  population           String?    @map("population")
  province             String?    @map("province")
  phone                String?    @map("phone")
  paymentMethod        String?    @map("payment_method")
  bank                 String?    @map("bank")
  bicSwift             String?    @map("bic_swift")
  iban                 String?    @map("iban")
  observations         String?    @map("observations") @db.Text
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  activationToken      String?    @unique @map("activation_token")
  isActive             Boolean    @default(false) @map("is_active")
  resetPasswordExpires DateTime?  @map("reset_password_expires")
  resetPasswordToken   String?    @unique @map("reset_password_token")
  acceptCommunications Boolean    @default(false) @map("accept_communications")
  contracts            Contract[]
  invoices             Invoice[]

  @@map("users")
}

model StorageType {
  id           Int           @id @default(autoincrement())
  description  String
  storageUnits StorageUnit[]

  @@map("storage_types")
}

model StorageUnit {
  id           Int           @id @default(autoincrement())
  number       String        @unique
  typeId       Int           @map("type_id")
  price        Decimal       @db.Decimal(10, 2)
  m2           Decimal       @db.Decimal(10, 2)
  m3           Decimal       @db.Decimal(10, 2)
  location     String
  status       StorageStatus @default(FREE)
  observations String?       @db.Text
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  contracts    Contract[]
  invoices     Invoice[]
  ipcHistory   IpcHistory[]
  type         StorageType   @relation(fields: [typeId], references: [id])

  @@index([typeId], map: "storage_units_type_id_fkey")
  @@map("storage_units")
}

model Contract {
  id                Int         @id @default(autoincrement())
  userId            Int         @map("user_id")
  storageUnitId     Int         @map("storage_unit_id")
  startDate         DateTime    @map("start_date")
  endDate           DateTime?   @map("end_date")
  content           String?     @db.Text
  insuranceCoverage Decimal?    @map("insurance_coverage") @db.Decimal(10, 2)
  currentPrice      Decimal     @map("current_price") @db.Decimal(10, 2)
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  storageUnit       StorageUnit @relation(fields: [storageUnitId], references: [id])
  user              User        @relation(fields: [userId], references: [id])

  @@index([storageUnitId], map: "contracts_storage_unit_id_fkey")
  @@index([userId], map: "contracts_user_id_fkey")
  @@map("contracts")
}

model Invoice {
  id            Int           @id @default(autoincrement())
  date          DateTime      @default(now())
  number        String        @unique
  series        String?
  userId        Int           @map("user_id")
  storageUnitId Int           @map("storage_unit_id")
  taxBase       Decimal       @map("tax_base") @db.Decimal(10, 2)
  vatAmount     Decimal       @map("vat_amount") @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  status        InvoiceStatus @default(PENDING)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  storageUnit   StorageUnit   @relation(fields: [storageUnitId], references: [id])
  user          User          @relation(fields: [userId], references: [id])

  @@index([storageUnitId], map: "invoices_storage_unit_id_fkey")
  @@index([userId], map: "invoices_user_id_fkey")
  @@map("invoices")
}

model IpcBatch {
  id           Int          @id @default(autoincrement())
  date         DateTime     @default(now())
  percentage   Decimal      @db.Decimal(5, 2)
  observations String?      @db.Text
  history      IpcHistory[]

  @@map("ipc_batches")
}

model IpcHistory {
  id               Int         @id @default(autoincrement())
  batchId          Int         @map("batch_id")
  storageUnitId    Int         @map("storage_unit_id")
  oldPrice         Decimal     @map("old_price") @db.Decimal(10, 2)
  newPrice         Decimal     @map("new_price") @db.Decimal(10, 2)
  difference       Decimal     @db.Decimal(10, 2)
  oldContractPrice Decimal     @map("old_contract_price") @db.Decimal(10, 2)
  newContractPrice Decimal     @map("new_contract_price") @db.Decimal(10, 2)
  createdAt        DateTime    @default(now()) @map("created_at")
  batch            IpcBatch    @relation(fields: [batchId], references: [id])
  storageUnit      StorageUnit @relation(fields: [storageUnitId], references: [id])

  @@index([batchId], map: "ipc_history_batch_id_fkey")
  @@index([storageUnitId], map: "ipc_history_storage_unit_id_fkey")
  @@map("ipc_history")
}

enum UserType {
  PARTICULAR
  EMPRESA
}

enum Role {
  USER
  ADMIN
}

enum StorageStatus {
  FREE
  OCCUPIED
  RESERVED
  NOT_AVAILABLE
}

enum InvoiceStatus {
  PAID
  PENDING
  RETURNED
}
